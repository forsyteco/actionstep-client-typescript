{
  "name": "@forsyteco/actionstep-client-typescript",
  "version": "0.1.3",
  "description": "TypeScript Actionstep API client generated with Hey API.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/forsyteco/actionstep-client-typescript.git"
  },
  "bugs": {
    "url": "https://github.com/forsyteco/actionstep-client-typescript/issues"
  },
  "homepage": "https://github.com/forsyteco/actionstep-client-typescript#readme",
  "keywords": [
    "actionstep",
    "openapi",
    "typescript",
    "nest",
    "hey-api"
  ],
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "rimraf dist",
    "preflight-specs": "tsx scripts/preflight-specs.ts",
    "sync-exports": "tsx scripts/sync-exports.ts",
    "generate": "npm run preflight-specs && openapi-ts && npm run sync-exports",
    "build": "npm run clean && tsc -p tsconfig.build.json",
    "test": "tsx --test src/**/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "npm run typecheck && npm run test",
    "prepack": "npm run lint && npm run build",
    "pack:check": "npm pack --dry-run",
    "publish:public": "npm publish --access public",
    "release:patch": "npm version patch && git push && git push --tags",
    "release:minor": "npm version minor && git push && git push --tags",
    "release:major": "npm version major && git push && git push --tags"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "^0.87.3",
    "@types/node": "^22.15.3",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  }
}
